<% selected_task_name = @selected_task_name.presence || "Task #{@selected_task_index + 1}" %>
<% final_width = @task.dig("output", "width").presence || @task.dig("canvas", "width") || 1650 %>
<% final_height = @task.dig("output", "height").presence || @task.dig("canvas", "height") || 2480 %>
<% selected_layout_mode = @task["layoutMode"].presence || @config["layoutMode"].presence || "strict" %>

<main class="page">
  <header class="page-header compact">
    <div>
      <h1><%= @image_project.name %></h1>
      <p>Status: <span class="status"><%= @image_project.status %></span></p>
    </div>
    <%= link_to "All Projects", image_projects_path, class: "button" %>
  </header>

  <% if notice.present? %>
    <div class="flash notice"><%= notice %></div>
  <% end %>
  <% if alert.present? %>
    <div class="flash alert"><%= alert %></div>
  <% end %>

  <section class="workflow-panel" aria-label="Generation workflow">
    <div class="workflow-step">
      <div>
        <span class="step-label">Step 1</span>
        <h2>Import Excel</h2>
        <p>Import an Excel instruction file to create image tasks automatically.</p>
      </div>
      <%= form_with url: import_excel_image_project_path(@image_project, task_index: @selected_task_index), method: :post, multipart: true, class: "workflow-form", data: { upload_reminder: true, upload_kind: "excel", upload_pending_label: "Import Excel Now" } do |form| %>
        <%= form.file_field :excel_file, accept: ".xlsx,.xls" %>
        <button type="submit" class="button primary" data-processing-label="Uploading...">Import Excel</button>
        <p class="upload-reminder-message" hidden data-upload-reminder-message>File selected but not uploaded yet.</p>
      <% end %>
    </div>

    <div class="workflow-step">
      <div>
        <span class="step-label">Step 2</span>
        <h2>Upload Images</h2>
        <p>Upload all source images referenced by the Excel file.</p>
      </div>
      <%= form_with url: upload_images_image_project_path(@image_project, task_index: @selected_task_index), method: :post, multipart: true, class: "workflow-form", data: { upload_reminder: true, upload_kind: "images", upload_action: "Upload", upload_singular: "Image", upload_plural: "Images" } do |form| %>
        <%= form.file_field :images, multiple: true, include_hidden: false, accept: ".png,.jpg,.jpeg,.webp" %>
        <button type="submit" class="button" data-processing-label="Uploading...">Upload Images</button>
        <p class="upload-reminder-message" hidden data-upload-reminder-message>File selected but not uploaded yet.</p>
      <% end %>
    </div>

    <div class="workflow-step generate-step">
      <div>
        <span class="step-label">Step 3</span>
        <h2>Preview / Download</h2>
        <p>Preview the selected image, then download the final ZIP for all images.</p>
      </div>
      <div class="selected-task-banner">
        <span>Selected Image: <strong><%= selected_task_name %></strong></span>
      </div>
      <div class="workflow-actions">
        <div class="workflow-action-item">
          <%= button_tag "Preview Selected Image", type: "submit", form: "task-editor-form", name: "after_save_action", value: "preview_current", class: "button", disabled: !@selected_task_previewable, data: { processing_label: "Generating preview..." } %>
          <% unless @selected_task_previewable %>
            <p class="field-help workflow-disabled-message"><%= @selected_task_preview_readiness[:message] %></p>
          <% end %>
        </div>
        <div class="workflow-action-item">
          <%= button_tag "Download ZIP (All Images)", type: "submit", form: "task-editor-form", name: "after_save_action", value: "download_zip", class: "button success", disabled: !@project_downloadable, data: { processing_label: "Generating images and preparing ZIP..." } %>
          <% unless @project_downloadable %>
            <p class="field-help workflow-disabled-message"><%= @project_download_readiness[:message] %></p>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <div class="workspace">
    <aside class="panel task-panel">
      <div class="panel-heading">
        <div>
          <h2>Select Task</h2>
        </div>
        <%= button_to "Add", add_task_image_project_path(@image_project), method: :post, class: "button small" %>
      </div>
      <p class="helper-text">Select a task below to preview that image.</p>

      <div class="task-list">
        <% @tasks.each_with_index do |task, index| %>
          <% status = @task_statuses[index] || empty_task_status(task) %>
          <% selected = index == @selected_task_index %>
          <div class="task-item <%= "active" if index == @selected_task_index %> status-<%= status[:status] %>">
            <%= link_to image_project_path(@image_project, task_index: index), class: "task-select-card", aria: (selected ? { current: "page" } : {}) do %>
              <div class="task-main-row">
                <span class="task-title"><%= status[:target_name] %></span>
                <span class="selection-badge <%= "selected" if selected %>"><%= selected ? "Selected" : "Select" %></span>
              </div>
              <div class="task-subtext">
                <%= pluralize(status[:layer_count], "layer") %>
                <% if status[:warnings].any? %>
                  &middot; <%= pluralize(status[:warnings].size, "warning") %>
                <% end %>
                <% if status[:errors].any? %>
                  &middot; <%= pluralize(status[:errors].size, "error") %>
                <% end %>
                &middot; <span class="status-text status-<%= status[:status] %>"><%= status[:label] %></span>
              </div>
            <% end %>
            <div class="task-actions">
              <%= button_to "Up", move_task_image_project_path(@image_project, task_index: index, direction: "up"), method: :post, class: "button tiny" %>
              <%= button_to "Down", move_task_image_project_path(@image_project, task_index: index, direction: "down"), method: :post, class: "button tiny" %>
              <%= button_to "Duplicate", duplicate_task_image_project_path(@image_project, task_index: index), method: :post, class: "button tiny" %>
              <%= button_to "Delete", delete_task_image_project_path(@image_project, task_index: index), method: :post, class: "button tiny danger" %>
            </div>
          </div>
        <% end %>
      </div>
    </aside>

    <main class="main-stack">
      <section class="panel preview-panel main-preview">
        <div class="panel-heading">
          <h2>Preview for <%= selected_task_name %></h2>
          <span class="status-badge status-<%= @selected_task_status[:status] %>"><%= @selected_task_status[:label] %></span>
        </div>
        <p class="current-task-name">Selected Image: <strong><%= selected_task_name %></strong></p>
        <p class="preview-scale-note">Preview is scaled for browser display. Final output size: <strong><%= final_width %> x <%= final_height %></strong>. Download ZIP contains full-size generated images for all tasks.</p>
        <div class="preview-stage">
          <% if @preview_matches_selected_task %>
            <p class="preview-owner">Scaled preview for <%= @selected_task_preview.task_name %></p>
            <%= image_tag @selected_task_preview.file, class: "preview-image" %>
          <% else %>
            <div class="preview-empty">
              <p class="empty-note">No up-to-date preview generated for <%= selected_task_name %> yet.</p>
              <p class="empty-note">Click Preview Selected Image to generate one.</p>
              <% if @stale_task_preview.present? %>
                <p class="muted">An older preview for <%= @stale_task_preview.task_name %> is outdated.</p>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>

    <section class="panel editor-panel">
      <%= form_with model: @image_project, method: :patch, class: "stack", id: "task-editor-form" do |form| %>
        <%= hidden_field_tag :task_index, @selected_task_index %>

        <div class="form-toolbar">
          <label class="grow">
            <span>Project Name</span>
            <%= form.text_field :name %>
          </label>
          <button type="submit" class="button primary" data-processing-label="Saving...">Save Changes</button>
        </div>

        <div class="section-heading">
          <h2>Selected Image Settings: <%= selected_task_name %></h2>
          <span><%= @selected_task_index + 1 %> of <%= @tasks.size %></span>
        </div>

        <div class="form-grid">
          <label>
            <span>Output Image Name</span>
            <%= text_field_tag "task[targetName]", @task["targetName"] %>
          </label>
          <label>
            <span>Canvas Width</span>
            <%= number_field_tag "task[canvas][width]", @task.dig("canvas", "width"), min: 1 %>
          </label>
          <label>
            <span>Canvas Height</span>
            <%= number_field_tag "task[canvas][height]", @task.dig("canvas", "height"), min: 1 %>
          </label>
          <label>
            <span>Background Color</span>
            <%= text_field_tag "task[canvas][backgroundColor]", @task.dig("canvas", "backgroundColor") %>
          </label>
          <label class="check-row">
            <%= hidden_field_tag "task[canvas][transparent]", "0" %>
            <%= check_box_tag "task[canvas][transparent]", "1", @task.dig("canvas", "transparent") == true %>
            <span>Transparent Background</span>
          </label>
          <label>
            <span>Output Width</span>
            <%= number_field_tag "task[output][width]", @task.dig("output", "width"), min: 1 %>
          </label>
          <label>
            <span>Output Height</span>
            <%= number_field_tag "task[output][height]", @task.dig("output", "height"), min: 1 %>
          </label>
          <label>
            <span>Output Format</span>
            <%= select_tag "task[output][format]", options_for_select(%w[png jpg webp], @task.dig("output", "format")) %>
          </label>
          <label>
            <span>Layout Mode</span>
            <%= select_tag "task[layoutMode]", options_for_select([["Strict Excel values", "strict"], ["Design-friendly layout", "design"]], selected_layout_mode) %>
            <small class="field-help">Design-friendly layout may enlarge visually undersized product images.</small>
          </label>
        </div>

        <details class="editor-details layers-panel">
          <summary>
            <span>Fine-tune Layers</span>
            <span class="summary-meta"><%= pluralize(@task.fetch("layers", []).size, "layer") %></span>
          </summary>
          <div class="details-body">
            <div class="section-heading compact-heading">
              <h2>Layers</h2>
              <div class="inline-actions">
                <%= button_tag "Add Image Layer", type: "submit", name: "editor_operation", value: "add_image_layer", class: "button small" %>
                <%= button_tag "Add Text Layer", type: "submit", name: "editor_operation", value: "add_text_layer", class: "button small" %>
              </div>
            </div>

            <% @task.fetch("layers", []).each_with_index do |layer, index| %>
              <% layer_type = layer["type"].presence || "text" %>
              <% spread_mode = layer["letterSpacingMode"].to_s == "spread" %>
              <article class="layer-card" data-controller="conditional-sections" data-conditional-sections-source-attribute-value="layer-type-source" data-conditional-sections-section-attribute-value="layer-type-section">
                <div class="layer-header">
                  <strong><%= layer["name"].presence || "Layer #{index + 1}" %></strong>
                  <div class="inline-actions">
                    <%= button_tag "Up", type: "submit", name: "editor_operation", value: "move_layer:#{index}:up", class: "button tiny" %>
                    <%= button_tag "Down", type: "submit", name: "editor_operation", value: "move_layer:#{index}:down", class: "button tiny" %>
                    <%= button_tag "Copy", type: "submit", name: "editor_operation", value: "duplicate_layer:#{index}", class: "button tiny" %>
                    <%= button_tag "Delete", type: "submit", name: "editor_operation", value: "delete_layer:#{index}", class: "button tiny danger" %>
                  </div>
                </div>

                <%= hidden_field_tag "layers[#{index}][id]", layer["id"] %>
                <div class="form-grid">
                  <label>
                    <span>Layer Name</span>
                    <%= text_field_tag "layers[#{index}][name]", layer["name"] %>
                  </label>
                  <label>
                    <span>Layer Type</span>
                    <%= select_tag "layers[#{index}][type]", options_for_select(%w[image text], layer_type), data: { layer_type_source: true, action: "change->conditional-sections#update" } %>
                  </label>
                  <label>
                    <span>X</span>
                    <%= text_field_tag "layers[#{index}][x]", layer["x"] %>
                  </label>
                  <label>
                    <span>Y</span>
                    <%= text_field_tag "layers[#{index}][y]", layer["y"] %>
                  </label>

                  <label data-layer-type-section="image" <%= "hidden" unless layer_type == "image" %>>
                    <span>Source Image</span>
                    <%= text_field_tag "layers[#{index}][imageName]", layer["imageName"] %>
                  </label>
                  <label data-layer-type-section="image" <%= "hidden" unless layer_type == "image" %>>
                    <span>Width</span>
                    <%= number_field_tag "layers[#{index}][width]", layer["width"].presence || 800, min: 1 %>
                  </label>
                  <label data-layer-type-section="image" <%= "hidden" unless layer_type == "image" %>>
                    <span>Height</span>
                    <%= number_field_tag "layers[#{index}][height]", layer["height"].presence || 800, min: 1 %>
                  </label>
                  <label data-layer-type-section="image" <%= "hidden" unless layer_type == "image" %>>
                    <span>Fit Mode</span>
                    <%= select_tag "layers[#{index}][fit]", options_for_select(%w[contain cover stretch], layer["fit"].presence || "contain") %>
                  </label>

                  <label class="span-2" data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                    <span>Text Content</span>
                    <%= text_area_tag "layers[#{index}][text]", layer["text"], rows: 3 %>
                    <small class="field-help">Inline formatting supported: **bold** and *italic*. Example: **DESIGN** HIGHLIGHTS</small>
                  </label>
                  <label class="font-field span-2" data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                    <span>Font</span>
                    <div class="font-picker-row">
                      <%= select_tag "layers[#{index}][font]", options_for_select(font_options_for(layer["font"]), layer["font"].to_s.strip) %>
                      <%= link_to "Upload new font", "#global-font-upload-form", class: "button tiny", data: { open_font_library: true } %>
                    </div>
                    <small class="field-help">Upload fonts once to the global library, then select them here.</small>
                  </label>
                  <label data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                    <span>Font Size</span>
                    <%= number_field_tag "layers[#{index}][fontSize]", layer["fontSize"].presence || 60, min: 1 %>
                  </label>
                  <label data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                    <span>Text Color</span>
                    <%= text_field_tag "layers[#{index}][color]", layer["color"].presence || "#1F1F1F" %>
                  </label>
                  <label data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                    <span>Letter Spacing</span>
                    <%= number_field_tag "layers[#{index}][letterSpacingRatio]", layer["letterSpacingRatio"] || 0, step: 0.01 %>
                    <small class="field-help">0.3 means 30% of font size. With font size 80, 0.3 = 24px.</small>
                    <small class="field-help">Large values such as 0.65 create very wide tracking.</small>
                  </label>
                  <label data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                    <span>Line Height</span>
                    <%= number_field_tag "layers[#{index}][lineHeightRatio]", layer["lineHeightRatio"] || 1.2, step: 0.05 %>
                  </label>
                  <label data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                    <span>Max Width</span>
                    <%= number_field_tag "layers[#{index}][maxWidth]", layer["maxWidth"].presence || 1200, min: 1 %>
                  </label>
                  <label data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                    <span>Alignment</span>
                    <%= select_tag "layers[#{index}][align]", options_for_select(%w[left center right], layer["align"].presence || "center") %>
                  </label>
                  <label class="check-row compact-check" data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                    <%= hidden_field_tag "layers[#{index}][autoWrap]", "0" %>
                    <%= check_box_tag "layers[#{index}][autoWrap]", "1", layer.key?("autoWrap") ? layer["autoWrap"] == true : true %>
                    <span>Auto Wrap</span>
                  </label>
                </div>

                <details class="layer-advanced">
                  <summary>Advanced layer options</summary>
                  <div class="form-grid" data-controller="conditional-sections" data-conditional-sections-source-attribute-value="letter-spacing-mode-source" data-conditional-sections-section-attribute-value="letter-spacing-mode-section" data-conditional-sections-disable-hidden-value="true">
                    <label>
                      <span>Opacity</span>
                      <%= number_field_tag "layers[#{index}][opacity]", layer["opacity"] || 1, min: 0, max: 1, step: 0.01 %>
                    </label>
                    <label class="check-row compact-check" data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                      <%= hidden_field_tag "layers[#{index}][bold]", "0" %>
                      <%= check_box_tag "layers[#{index}][bold]", "1", layer["bold"] == true %>
                      <span>Bold</span>
                      <small class="field-help">Whole-layer Bold affects all text. For only one word, use **word** in Text Content.</small>
                    </label>
                    <label class="check-row compact-check" data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                      <%= hidden_field_tag "layers[#{index}][italic]", "0" %>
                      <%= check_box_tag "layers[#{index}][italic]", "1", layer["italic"] == true %>
                      <span>Italic</span>
                    </label>
                    <label data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                      <span>Letter Spacing Mode</span>
                      <%= select_tag "layers[#{index}][letterSpacingMode]", options_for_select([["Ratio", ""], ["Spread to target width", "spread"]], layer["letterSpacingMode"].to_s), data: { letter_spacing_mode_source: true, action: "change->conditional-sections#update" } %>
                    </label>
                    <label id="layer-<%= index %>-target-text-width-ratio-field" data-layer-type-section="text" data-letter-spacing-mode-section="spread" <%= "hidden" unless layer_type == "text" && spread_mode %>>
                      <span>Target Text Width Ratio</span>
                      <%= number_field_tag "layers[#{index}][targetTextWidthRatio]", layer["targetTextWidthRatio"] || 0.78, min: 0.5, max: 0.95, step: 0.01, disabled: !spread_mode %>
                    </label>
                    <label class="span-2" data-layer-type-section="text" <%= "hidden" unless layer_type == "text" %>>
                      <span>Notes</span>
                      <%= text_area_tag "layers[#{index}][notes]", layer["notes"], rows: 2 %>
                    </label>
                  </div>
                </details>
              </article>
            <% end %>
          </div>
        </details>
      <% end %>
    </section>
    </main>

    <aside class="side-stack">
      <section class="panel">
        <h2>Warnings / Errors for <%= selected_task_name %></h2>
        <% if @selected_task_status[:errors].any? || @selected_task_status[:warnings].any? %>
          <div class="message-list">
            <% @selected_task_status[:errors].each do |message| %>
              <p class="error-text"><%= message %></p>
            <% end %>
            <% @selected_task_status[:warnings].each do |message| %>
              <p class="warning-text"><%= message %></p>
            <% end %>
          </div>
        <% else %>
          <p class="empty-note">No current warnings or errors.</p>
        <% end %>
      </section>

      <section class="panel">
        <h2>Required Images</h2>
        <% if @readiness_summary[:images].any? %>
          <ul class="check-list compact-list">
            <% @readiness_summary[:images].each do |item| %>
              <li class="readiness-<%= item[:status] %>">
                <span class="readiness-icon <%= item[:status] == "matched" ? "ok" : "missing" %>" aria-hidden="true"><%= item[:status] == "matched" ? "&#10003;".html_safe : "&#10007;".html_safe %></span>
                <%= item[:message] %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-note">No image references found.</p>
        <% end %>
      </section>

      <section class="panel">
        <h2>Image Assets</h2>
        <div class="asset-list">
          <% @image_project.image_assets.each do |asset| %>
            <div class="asset-row">
              <% if asset.file.attached? %>
                <%= image_tag asset.file, class: "asset-thumb" %>
              <% end %>
              <div class="asset-meta">
                <span class="asset-label">Uploaded file</span>
                <strong><%= asset.name %></strong>
                <span>Dimensions: <%= [asset.width, asset.height].compact.join(" x ").presence || "unknown" %></span>
                <%= form_with url: update_image_asset_image_project_path(@image_project, asset_id: asset.id, task_index: @selected_task_index), method: :patch, class: "asset-alias-form" do %>
                  <label>
                    <span>Excel Match Name</span>
                    <%= text_field_tag "image_asset[alias_name]", asset.alias_name.presence || asset.normalized_name %>
                    <small class="field-help">If Excel says p1, this field should be p1.</small>
                  </label>
                  <%= submit_tag "Save", class: "button tiny" %>
                <% end %>
              </div>
              <%= button_to "Delete", image_asset_image_project_path(@image_project, asset_id: asset.id, task_index: @selected_task_index), method: :delete, class: "button tiny danger" %>
            </div>
          <% end %>
          <% if @image_project.image_assets.empty? %>
            <p class="empty-note">No image assets uploaded yet.</p>
          <% end %>
        </div>
      </section>

      <section class="panel font-library-panel" id="font-library">
        <div class="panel-heading">
          <h2>Font Library</h2>
          <span class="summary-meta"><%= pluralize(@global_font_assets.size, "global font") %></span>
        </div>

        <div class="sidebar-section">
          <h3>Required Fonts</h3>
          <% if @readiness_summary[:fonts].any? %>
            <ul class="check-list compact-list">
              <% @readiness_summary[:fonts].each do |item| %>
                <li class="readiness-<%= item[:status] %>">
                  <span class="readiness-icon <%= item[:status] == "matched" ? "ok" : "warning" %>" aria-hidden="true"><%= item[:status] == "matched" ? "&#10003;".html_safe : "&#9888;".html_safe %></span>
                  <%= item[:message] %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="empty-note">No font references found.</p>
          <% end %>
        </div>

        <% font_library_manager_open = @readiness_summary[:fonts].any? { |item| item[:status] != "matched" } %>
        <details id="font-library-manager" class="compact-details" <%= "open" if font_library_manager_open %>>
          <summary>Manage Font Library</summary>
          <div class="details-body">
            <%= form_with url: upload_global_fonts_image_project_path(@image_project, task_index: @selected_task_index), method: :post, multipart: true, id: "global-font-upload-form", class: "workflow-form compact-upload-form", data: { upload_reminder: true, upload_kind: "global-fonts", upload_action: "Upload", upload_singular: "Font", upload_plural: "Fonts" } do |form| %>
              <%= form.file_field :fonts, multiple: true, include_hidden: false, accept: ".ttf,.otf,.woff,.woff2", id: "global-font-file-input", data: { global_font_file_input: true } %>
              <label>
                <span>Excel Match Name</span>
                <%= text_field_tag "global_font_asset[match_name]", nil, placeholder: "Optional for one font" %>
              </label>
              <button type="submit" class="button" data-processing-label="Uploading...">Upload Font</button>
              <p id="global-font-upload-helper" class="field-help" data-font-library-helper>Choose .ttf, .otf, .woff, or .woff2 font files.</p>
              <p class="upload-reminder-message" hidden data-upload-reminder-message>File selected but not uploaded yet.</p>
            <% end %>

            <div class="asset-list">
              <h3>Global Uploaded Fonts</h3>
              <% @global_font_assets.each do |asset| %>
                <div class="asset-row no-thumb">
                  <div class="asset-meta">
                    <span class="asset-label">Global</span>
                    <strong><%= asset.name %></strong>
                    <%= form_with url: update_global_font_asset_image_project_path(@image_project, asset_id: asset.id, task_index: @selected_task_index), method: :patch, class: "asset-alias-form" do %>
                      <label>
                        <span>Excel Match Name</span>
                        <%= text_field_tag "global_font_asset[match_name]", asset.match_name.presence || asset.normalized_name %>
                      </label>
                      <%= submit_tag "Save", class: "button tiny" %>
                    <% end %>
                  </div>
                  <%= button_to "Delete", global_font_asset_image_project_path(@image_project, asset_id: asset.id, task_index: @selected_task_index), method: :delete, class: "button tiny danger", form: { data: { turbo_confirm: "Delete this global font for all projects?" } } %>
                </div>
              <% end %>
              <% if @global_font_assets.empty? %>
                <p class="empty-note">No global fonts uploaded yet.</p>
              <% end %>
            </div>

            <% if @project_font_assets.any? %>
              <details class="compact-details legacy-fonts">
                <summary>Project legacy fonts (<%= @project_font_assets.size %>)</summary>
                <div class="asset-list">
                  <% @project_font_assets.each do |asset| %>
                    <div class="asset-row no-thumb">
                      <div class="asset-meta">
                        <span class="asset-label">Project</span>
                        <strong><%= asset.name %></strong>
                        <%= form_with url: update_font_asset_image_project_path(@image_project, asset_id: asset.id, task_index: @selected_task_index), method: :patch, class: "asset-alias-form" do %>
                          <label>
                            <span>Excel Match Name</span>
                            <%= text_field_tag "font_asset[alias_name]", asset.alias_name.presence || asset.normalized_name %>
                          </label>
                          <%= submit_tag "Save", class: "button tiny" %>
                        <% end %>
                      </div>
                      <%= button_to "Delete", font_asset_image_project_path(@image_project, asset_id: asset.id, task_index: @selected_task_index), method: :delete, class: "button tiny danger" %>
                    </div>
                  <% end %>
                </div>
              </details>
            <% end %>
          </div>
        </details>
      </section>

      <% if @latest_job %>
        <section class="panel">
          <h2>Latest Generation</h2>
          <p>Status: <span class="status"><%= @latest_job.status %></span></p>
          <div class="generated-list">
            <% @latest_job.generated_images.each do |generated| %>
              <div class="generated-row">
                <strong><%= generated.target_name %>.<%= generated.format %></strong>
                <% if generated.width.present? && generated.height.present? %>
                  <span><%= generated.width %> x <%= generated.height %></span>
                <% end %>
                <% if generated.errors_list.any? %>
                  <span class="error-text"><%= generated.errors_list.join(" | ") %></span>
                <% elsif generated.warnings_list.any? %>
                  <span class="warning-text"><%= generated.warnings_list.join(" | ") %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <details class="panel advanced-panel">
        <summary>Advanced JSON</summary>
        <%= form_with model: @image_project, method: :patch, class: "stack advanced-json-form" do |form| %>
          <%= hidden_field_tag :task_index, @selected_task_index %>
          <%= form.text_field :name %>
          <%= text_area_tag :config_json_text, @image_project.config_json, rows: 18, class: "json-box" %>
          <button type="submit" class="button" data-processing-label="Saving...">Save Raw JSON</button>
        <% end %>
      </details>

      <section class="panel danger-zone">
        <h2>Danger Zone</h2>
        <p>Delete this project and all uploaded/generated files. This cannot be undone.</p>
        <%= link_to "Delete Project", delete_confirmation_image_project_path(@image_project, return_to: image_project_path(@image_project, task_index: @selected_task_index)), class: "button danger" %>
      </section>
    </aside>
  </div>
</main>

<script>
  (function() {
    function submitControlFor(form) {
      return form.querySelector('input[type="submit"], button[type="submit"]');
    }

    function labelFor(control) {
      if (control.matches('input')) {
        return control.value;
      }

      return control.textContent;
    }

    function setLabel(control, label) {
      if (control.matches('input')) {
        control.value = label;
      } else {
        control.textContent = label;
      }
    }

    function submitterForEvent(event) {
      if (event.submitter) {
        return event.submitter;
      }

      var active = document.activeElement;
      if (active && active.form === event.target && active.matches('button, input[type="submit"]')) {
        return active;
      }

      return submitControlFor(event.target);
    }

    function defaultProcessingLabel(control, form) {
      var action = control.value || "";
      var label = labelFor(control).trim().toLowerCase();

      if (action === "preview_current") {
        return "Generating preview...";
      }

      if (action === "download_zip") {
        return "Generating images and preparing ZIP...";
      }

      if (label.indexOf("generate") !== -1) {
        return "Generating...";
      }

      if (form.enctype === "multipart/form-data" || label.indexOf("upload") !== -1 || label.indexOf("import") !== -1) {
        return "Uploading...";
      }

      if (label.indexOf("save") !== -1) {
        return "Saving...";
      }

      return "Processing...";
    }

    function preserveSubmitterValue(form, control) {
      if (!control || !control.name) {
        return null;
      }

      var hidden = document.createElement("input");
      hidden.type = "hidden";
      hidden.name = control.name;
      hidden.value = control.value;
      hidden.dataset.submitterValue = "true";
      form.appendChild(hidden);
      return hidden;
    }

    function setProcessingState(form, control) {
      if (!control) {
        return;
      }

      if (!control.dataset.defaultLabel) {
        control.dataset.defaultLabel = labelFor(control);
      }
      control.dataset.wasDisabled = control.disabled ? "true" : "false";

      setLabel(control, control.dataset.processingLabel || defaultProcessingLabel(control, form));
      control.classList.add("is-processing");
      control.setAttribute("aria-busy", "true");
      control.disabled = true;
    }

    function resetProcessingState(form, control, hidden) {
      if (hidden && hidden.parentNode) {
        hidden.parentNode.removeChild(hidden);
      }

      if (control) {
        if (control.dataset.defaultLabel) {
          setLabel(control, control.dataset.defaultLabel);
        }
        control.classList.remove("is-processing");
        control.removeAttribute("aria-busy");
        control.disabled = control.dataset.wasDisabled === "true";
        delete control.dataset.wasDisabled;
      }

      if (form) {
        delete form.dataset.submitting;
      }
    }

    function downloadFetchSupported() {
      return window.fetch && window.FormData && window.Blob && window.URL && window.URL.createObjectURL;
    }

    function csrfToken() {
      var token = document.querySelector('meta[name="csrf-token"]');
      return token ? token.content : "";
    }

    function isDownloadZipSubmit(form, control) {
      return form &&
        form.id === "task-editor-form" &&
        control &&
        control.name === "after_save_action" &&
        control.value === "download_zip";
    }

    function filenameFromDisposition(disposition) {
      var utf8Match = disposition.match(/filename\*=UTF-8''([^;]+)/i);
      if (utf8Match) {
        try {
          return decodeURIComponent(utf8Match[1].replace(/"/g, ""));
        } catch (error) {
          return utf8Match[1].replace(/"/g, "");
        }
      }

      var filenameMatch = disposition.match(/filename="?([^";]+)"?/i);
      return filenameMatch ? filenameMatch[1] : null;
    }

    function triggerBlobDownload(blob, filename) {
      var url = window.URL.createObjectURL(blob);
      var link = document.createElement("a");
      link.href = url;
      link.download = filename || "generated-images.zip";
      link.style.display = "none";
      document.body.appendChild(link);
      link.click();
      window.setTimeout(function() {
        window.URL.revokeObjectURL(url);
        if (link.parentNode) {
          link.parentNode.removeChild(link);
        }
      }, 0);
    }

    function navigateToHtmlResponse(response) {
      if (response.redirected && response.url) {
        window.location.assign(response.url);
        return Promise.resolve();
      }

      return response.text().then(function(html) {
        var contentType = response.headers.get("Content-Type") || "";
        if (contentType.indexOf("text/html") !== -1 && html) {
          document.open();
          document.write(html);
          document.close();
        } else if (response.url) {
          window.location.assign(response.url);
        } else {
          window.location.reload();
        }
      });
    }

    function submitDownloadZipWithFetch(form, control, hidden) {
      var formData = new FormData(form);
      var method = (form.getAttribute("method") || "get").toUpperCase();

      return fetch(form.action, {
        method: method,
        body: formData,
        credentials: "same-origin",
        headers: {
          "Accept": "application/zip, text/html;q=0.9, */*;q=0.8",
          "X-CSRF-Token": csrfToken()
        }
      }).then(function(response) {
        var contentType = response.headers.get("Content-Type") || "";
        if (response.ok && contentType.indexOf("application/zip") !== -1) {
          return response.blob().then(function(blob) {
            triggerBlobDownload(
              blob,
              filenameFromDisposition(response.headers.get("Content-Disposition") || "")
            );
          });
        }

        return navigateToHtmlResponse(response);
      }).catch(function(error) {
        console.error("Download ZIP request failed", error);
      }).finally(function() {
        resetProcessingState(form, control, hidden);
      });
    }

    function initializeProcessingState() {
      document.addEventListener("submit", function(event) {
        var form = event.target;
        var submitter = submitterForEvent(event);

        if (form.dataset.submitting === "true") {
          event.preventDefault();
          return;
        }

        form.dataset.submitting = "true";
        var hidden = preserveSubmitterValue(form, submitter);
        setProcessingState(form, submitter);

        if (isDownloadZipSubmit(form, submitter)) {
          if (downloadFetchSupported()) {
            event.preventDefault();
            submitDownloadZipWithFetch(form, submitter, hidden);
          } else {
            window.setTimeout(function() {
              resetProcessingState(form, submitter, hidden);
            }, 30000);
          }
        }
      });
    }

    function selectedFileCount(input) {
      if (!input) {
        return 0;
      }

      if (input.files) {
        return input.files.length;
      }

      return input.value ? 1 : 0;
    }

    function pendingLabelFor(form, count) {
      if (form.dataset.uploadPendingLabel) {
        return form.dataset.uploadPendingLabel;
      }

      var noun = count === 1 ? form.dataset.uploadSingular : form.dataset.uploadPlural;
      return [form.dataset.uploadAction || "Upload", count, noun, "Now"].filter(Boolean).join(" ");
    }

    function updateReminder(form) {
      var input = form.querySelector('input[type="file"]');
      var submitControl = submitControlFor(form);
      var message = form.querySelector('[data-upload-reminder-message]');

      if (!input || !submitControl || !message) {
        return;
      }

      if (!submitControl.dataset.defaultLabel) {
        submitControl.dataset.defaultLabel = labelFor(submitControl);
      }

      var count = selectedFileCount(input);
      var hasPendingFiles = count > 0;

      form.classList.toggle("upload-pending", hasPendingFiles);
      message.hidden = !hasPendingFiles;
      message.setAttribute("aria-live", "polite");

      if (!message.id) {
        message.id = "upload-reminder-" + (form.dataset.uploadKind || "file");
      }

      if (hasPendingFiles) {
        setLabel(submitControl, pendingLabelFor(form, count));
        submitControl.setAttribute("aria-describedby", message.id);
      } else {
        setLabel(submitControl, submitControl.dataset.defaultLabel);
        submitControl.removeAttribute("aria-describedby");
      }
    }

    function initializeUploadReminders() {
      document.querySelectorAll('form[data-upload-reminder]').forEach(function(form) {
        var input = form.querySelector('input[type="file"]');

        if (!input) {
          return;
        }

        input.addEventListener("change", function() {
          updateReminder(form);
        });
        form.addEventListener("reset", function() {
          window.setTimeout(function() {
            updateReminder(form);
          }, 0);
        });
        updateReminder(form);
      });
    }

    function highlightFontLibrary(panel, form) {
      [panel, form].forEach(function(element) {
        if (!element) {
          return;
        }

        element.classList.remove("font-library-highlight");
        void element.offsetWidth;
        element.classList.add("font-library-highlight");
        window.setTimeout(function() {
          element.classList.remove("font-library-highlight");
        }, 1800);
      });
    }

    function openFontLibrary(options) {
      var manager = document.getElementById("font-library-manager");
      var panel = document.getElementById("font-library");
      var form = document.getElementById("global-font-upload-form");
      var input = document.querySelector("[data-global-font-file-input]");
      var helper = document.querySelector("[data-font-library-helper]");
      options = options || {};

      if (manager) {
        manager.open = true;
      }

      if (helper && options.fromLayerControl) {
        helper.textContent = "Choose font files below.";
      }

      window.setTimeout(function() {
        var scrollTarget = form || panel || manager;
        if (scrollTarget) {
          scrollTarget.scrollIntoView({ behavior: "smooth", block: "center" });
        }
        if (options.focusInput && input) {
          try {
            input.focus({ preventScroll: true });
          } catch (error) {
            input.focus();
          }
        }
        highlightFontLibrary(panel, form);
      }, 0);
    }

    function initializeFontLibraryControls() {
      document.querySelectorAll("[data-open-font-library]").forEach(function(control) {
        control.addEventListener("click", function(event) {
          event.preventDefault();
          openFontLibrary({ focusInput: true, fromLayerControl: true });
        });
      });

      if (window.location.hash === "#font-library" || window.location.hash === "#global-font-upload-form") {
        openFontLibrary({ focusInput: window.location.hash === "#global-font-upload-form" });
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", function() {
        initializeUploadReminders();
        initializeFontLibraryControls();
        initializeProcessingState();
      });
    } else {
      initializeUploadReminders();
      initializeFontLibraryControls();
      initializeProcessingState();
    }
  })();
</script>
